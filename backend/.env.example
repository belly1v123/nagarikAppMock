# ═══════════════════════════════════════════════════════════════
# NAGARIK APP MOCK — Backend Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and update values for your environment

# ─────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nagarik:password@localhost:5432/nagarik_mock

# ─────────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────
# JWT secret for admin authentication (min 32 characters)
JWT_SECRET=your_admin_jwt_secret_min_32_chars_long_here

# JWT token expiry
JWT_EXPIRES_IN=8h

# Salt for hashing sensitive data (min 32 characters)
HASH_SALT=your_hash_salt_min_32_chars_long_here

# AES-256 encryption key (exactly 32 characters for AES-256)
ENCRYPTION_KEY=your_aes_256_key_exactly_32_c

# Secret for generating proof tokens (min 32 characters)
PROOF_SECRET=your_proof_token_secret_min_32_chars_here

# ─────────────────────────────────────────────────────────────────
# FACE MATCHING THRESHOLDS
# ─────────────────────────────────────────────────────────────────
# Lower distance = more similar faces
# Below match threshold = verified as same person
FACE_MATCH_THRESHOLD=0.50

# Below duplicate threshold = considered duplicate at registration
FACE_DUPLICATE_THRESHOLD=0.45

# Below high confidence = very strong match
FACE_HIGH_CONFIDENCE_THRESHOLD=0.40

# ─────────────────────────────────────────────────────────────────
# STORAGE
# ─────────────────────────────────────────────────────────────────
# Set to true to store face images (NOT recommended for production)
# By default, only face descriptors are stored
STORE_FACE_IMAGES=false

# ─────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────
# API key rate limit (requests per hour per key)
API_RATE_LIMIT_PER_HOUR=100

# General rate limit (requests per minute per IP)
GENERAL_RATE_LIMIT_PER_MINUTE=100
