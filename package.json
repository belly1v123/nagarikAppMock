{
    "name": "nagarik-mock",
    "version": "1.0.0",
    "private": true,
    "description": "Nepal Citizen Identity Platform - Mock Nagarik App",
    "scripts": {
        "dev": "concurrently -n backend,frontend,admin -c blue,green,yellow \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\" \"pnpm --filter @nagarik/admin dev\"",
        "dev:backend": "pnpm --filter backend dev",
        "dev:frontend": "pnpm --filter frontend dev",
        "dev:admin": "pnpm --filter @nagarik/admin dev",
        "build": "pnpm -r build",
        "build:types": "pnpm --filter @nagarik/types build",
        "db:migrate": "pnpm --filter backend migrate",
        "db:seed": "pnpm --filter backend seed",
        "db:generate": "pnpm --filter backend generate",
        "setup": "pnpm install && pnpm db:generate && pnpm build:types",
        "start": "pnpm dev"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "typescript": "^5.3.3"
    },
    "pnpm": {
        "overrides": {
            "esbuild": "0.21.5"
        }
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "packageManager": "pnpm@9.0.0"
}