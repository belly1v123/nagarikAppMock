{
    "name": "nagarik-mock",
    "version": "1.0.0",
    "private": true,
    "description": "Nepal Citizen Identity Platform - Mock Nagarik App",
    "workspaces": [
        "packages/*",
        "apps/*",
        "backend"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:admin\"",
        "dev:backend": "npm run dev --workspace=backend",
        "dev:frontend": "npm run dev --workspace=apps/frontend",
        "dev:admin": "npm run dev --workspace=apps/admin",
        "build": "npm run build --workspaces",
        "db:migrate": "npm run migrate --workspace=backend",
        "db:seed": "npm run seed --workspace=backend",
        "db:generate": "npm run generate --workspace=backend",
        "lint": "npm run lint --workspaces --if-present",
        "clean": "rimraf node_modules apps/*/node_modules packages/*/node_modules backend/node_modules"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "rimraf": "^5.0.5",
        "typescript": "^5.3.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}